<% content_for :title, "Início - CISALV" %>
<% content_for :description, "Consórcio Intermunicipal de Saúde Alto das Vertentes" %>

<section class="hero">
  <video class="hero-video" autoplay muted loop playsinline id="heroVideo">
    <source src="/videos/fundo_0.mp4" type="video/mp4">
  </video>
  <div class="hero-overlay"></div>
  <div class="container hero-content">
    <h1>CISALV</h1>
    <p class="subtitle">Consórcio Intermunicipal de Saúde Alto das Vertentes</p>
    <p class="city">Ressaquinha - MG</p>
  </div>
</section>

<section class="news-section">
  <div class="container">
    <h2 class="section-title">
      Notícias
      <a href="/noticias" class="section-link">Ver todas as notícias →</a>
    </h2>
    <div class="news-grid">
      <% if @noticias && @noticias.any? %>
        <% 
        conteudo = @noticias.first.conteudo_dinamico.to_s rescue ""
        img_matches = conteudo.match(/<img[^>]+src="(https?:\/\/lh7-rt[^"]+)"/)
        primeira_imagem = img_matches ? img_matches[1] : "/imgs/contratos.png"
        texto_preview = sanitize(conteudo.gsub(/<[^>]*>/, ' ').squish[0..150], tags: []) rescue ""
        %>
        <article class="news-featured" style="background-image: linear-gradient(rgba(240,248,255,0.92), rgba(240,248,255,0.92)), url('<%= primeira_imagem %>')">
          <a href="<%= "/noticias/#{@noticias.first.slug}" %>">
            <span class="news-date"><%= l @noticias.first.data_publicacao, format: :long if @noticias.first.data_publicacao %></span>
            <h3><%= @noticias.first.titulo %></h3>
            <div class="news-featured-content"><%= texto_preview %>...</div>
          </a>
        </article>
        <div class="news-list">
          <% @noticias.offset(1).limit(4).each do |noticia| %>
            <article class="news-item">
              <a href="<%= "/noticias/#{noticia.slug}" %>">
                <span class="news-date"><%= l noticia.data_publicacao, format: :long if noticia.data_publicacao %></span>
                <h4><%= noticia.titulo %></h4>
              </a>
            </article>
          <% end %>
        </div>
      <% else %>
        <article class="news-featured">
          <a href="#">
            <span class="news-date">Em breve</span>
            <h3>Nenhuma notícia disponível no momento</h3>
          </a>
        </article>
      <% end %>
    </div>
  </div>
</section>

<section class="departments-section">
  <div class="container">
    <h2 class="section-title">Programas</h2>
    <div class="departments-grid departments-grid-6">
      <div class="department-item" data-description="O CISALV realiza credenciamento para contratar prestadores de serviços de saúde, como exames, consultas especializadas, procedimentos médicos e cirurgias, atendendo aos 23 municípios consorciados.">
        <div class="department-card">
          <%= image_tag "programas/credenciamento.png", alt: "Credenciamento CISALV" %>
          <h3>Credenciamento CISALV</h3>
        </div>
        <div class="department-expanded"></div>
      </div>
      <div class="department-item" data-description="Através do Programa TRANSPORTA-SUS, nossos veículos realizam o transporte diário de pacientes para clínicas, hospitais e laboratórios, garantindo transporte seguro e gratuito.">
        <div class="department-card">
          <%= image_tag "programas/transporta-sus.png", alt: "Transporta-SUS", class: "icon-tall" %>
          <h3>Transporta-SUS</h3>
        </div>
        <div class="department-expanded"></div>
      </div>
      <div class="department-item" data-description="O Programa FarmaCis foi criado pela Secretaria de Estado de Saúde em parceria com o CISALV. Somos projeto piloto na criação e execução do programa, garantindo acesso aos medicamentos.">
        <div class="department-card">
          <%= image_tag "programas/farmacis.png", alt: "Farmacis" %>
          <h3>Farmacis</h3>
        </div>
        <div class="department-expanded"></div>
      </div>
      <div class="department-item" data-description="A Central de Compras Compartilhadas do CISALV visa unir esforços dos municípios consorciados para adquirir bens e serviços de forma conjunta, proporcionando economia de escala.">
        <div class="department-card">
          <%= image_tag "programas/medicamentos.png", alt: "Central de Compras" %>
          <h3>Central de Compras</h3>
        </div>
        <div class="department-expanded"></div>
      </div>
      <div class="department-item" data-description="O Programa VACIMÓVEL do CISALV oferece a immunization móvel para os municípios consorciados, com unidades móveis equipadas para realizar campanhas de vacinação.">
        <div class="department-card">
          <%= image_tag "programas/vacimovel.png", alt: "Vacimóvel" %>
          <h3>Vacimóvel</h3>
        </div>
        <div class="department-expanded"></div>
      </div>
      <div class="department-item" data-description="O Programa VISA-CIS visa fortalecer as ações de vigilância sanitária nos municípios consorciados, oferecendo apoio técnico e operacional para garantir a segurança sanitária.">
        <div class="department-card">
          <%= image_tag "programas/visacis.png", alt: "Visacis" %>
          <h3>Visacis</h3>
        </div>
        <div class="department-expanded"></div>
      </div>
    </div>
    <div class="department-description" id="departmentDescription">
      <p>Passe o mouse sobre um programa para saber mais.</p>
    </div>
  </div>
</section>

